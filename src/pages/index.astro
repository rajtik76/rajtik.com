---
const projects = [
  { name: 'Billify',        tag: 'invoicing API · CZ',     body: "Issue invoices over a clean REST API. Built for developers who'd rather call an endpoint than click through accounting software." },
  { name: 'CaptchaAPI',     tag: 'privacy CAPTCHA · EU',   body: 'Proof-of-work CAPTCHA, GDPR-first. No tracking, no Google. Ships with its own Laravel package and WordPress plugin.' },
  { name: 'POE2 Toolkit',   tag: 'game tooling · OSS',     body: 'Passive-tree & build-diff tooling for Path of Exile 2. GGPK parsing published as npm packages under @poe2-toolkit.' },
  { name: 'laravel-blog.cz', tag: 'writing · CZ',          body: 'A Czech-language blog where I write about Laravel and day-to-day backend engineering.' },
];

const packages = [
  { name: 'captchaapi/laravel', href: 'https://github.com/captchaapi/laravel',  reg: 'Composer · Packagist' },
  { name: 'captchaapi',         href: 'https://wordpress.org/plugins/captchaapi/', reg: 'WordPress.org · reviewed plugin' },
  { name: 'poe2-toolkit',       href: 'https://github.com/rajtik76/poe2-toolkit', reg: 'npm · GitHub', extra: '@poe2-toolkit/ggpk' },
];

const experience = [
  { yr: '2022 - now',  role: 'PHP Developer',          org: 'Freelance (OSVČ)',     desc: 'Web apps, REST + user-facing APIs, Livewire, Vue.js, PostgreSQL.' },
  { yr: '2021 - 2022', role: 'PHP Developer',          org: 'UBK s.r.o.',           desc: 'Laravel development across multiple client products.' },
  { yr: '2018 - 2021', role: 'Developer',              org: 'Freelance',            desc: 'CMS for an international company. SCRUM, English-only daily comms. PHP 8, Nette, MariaDB.' },
  { yr: '2016 - 2018', role: 'Developer',              org: 'MySolutions s.r.o.',   desc: 'Dating platforms across 12 countries. SCRUM, English-only standups. PHP, Nette, MySQL.' },
  { yr: 'earlier',     role: 'Embedded, IoT & systems engineering', org: null,      desc: 'Firmware in C (AVR/PIC), telemetry APIs, Linux/Windows servers; Delphi/FoxPro business apps.' },
];

const skills = ['PHP','Laravel','REST API design','PostgreSQL','Pest / PHPUnit','Livewire','Vue.js','Nette','Symfony','ElasticSearch','IoT / LoRaWAN','embedded C','Linux'];
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Vladislav Rajtmajer - PHP / Laravel Engineer</title>
<meta name="description" content="Senior PHP/Laravel engineer, 12+ years. REST APIs, PostgreSQL, IoT. Available for remote contracting." />
<link rel="canonical" href="https://rajtik.com/" />
<meta property="og:title" content="Vladislav Rajtmajer - PHP / Laravel Engineer" />
<meta property="og:description" content="Senior PHP/Laravel engineer, 12+ years. REST APIs, PostgreSQL, IoT. Available for remote contracting." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://rajtik.com/" />
<meta property="og:image" content="https://rajtik.com/og.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Vladislav Rajtmajer - PHP / Laravel Engineer" />
<meta name="twitter:description" content="Senior PHP/Laravel engineer, 12+ years. REST APIs, PostgreSQL, IoT. Available for remote contracting." />
<meta name="twitter:image" content="https://rajtik.com/og.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
<main class="term">
  <div class="bar">
    <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
    <span class="path">vladislav@rajtik: ~/about</span>
  </div>
  <div class="body">

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">whoami</span></p>
    <div class="blk">
      <h1>Vladislav Rajtmajer</h1>
      <p class="role">Senior PHP / Laravel Engineer</p>
      <p class="meta">Plzeň, Czech Republic · remote · contract (IČO)</p>
      <p class="avail"><span class="ok"></span> available now for new contracts</p>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">cat <span class="flag">about.md</span></span></p>
    <div class="blk out">
      12+ years building web applications and backend systems. I work mostly in
      Laravel: REST and user-facing API design, PostgreSQL, and the boring
      reliability work that keeps APIs predictable.
      <br /><br />
      Before the web I spent years in embedded and IoT: binary protocols between
      hardware and servers, telemetry data pipelines, even banknote-validator
      firmware in C on Atmel AVR. That low-level background still shapes how I
      design data interfaces.
      <br /><br />
      <span class="dim"># Open to long-term remote contracts on a modern PHP/Laravel stack.</span>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">ls <span class="flag">projects/</span></span></p>
    <div class="blk">
      <div class="grid">
        {projects.map((p) => (
          <article class="card">
            <h3>{p.name}</h3><span class="tag">{p.tag}</span>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">cat <span class="flag">packages.json</span> --published</span></p>
    <div class="blk">
      {packages.map((p) => (
        <div class="pkg">
          <span class="name"><a href={p.href}>{p.name}</a>{p.extra && <span class="dim"> · {p.extra}</span>}</span>
          <span class="reg">{p.reg}</span>
        </div>
      ))}
      <p class="badge">ships across 3 ecosystems: Composer · WordPress.org · npm</p>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">git log <span class="flag">--oneline</span> --career</span></p>
    <div class="blk">
      {experience.map((e) => (
        <div class="exp">
          <span class="yr">{e.yr}</span>
          <span><span class="ro">{e.role}</span>{e.org && <> · <span class="co">{e.org}</span></>}</span>
          <span class="de">{e.desc}</span>
        </div>
      ))}
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">cat <span class="flag">stack.txt</span></span></p>
    <div class="blk">
      <div class="chips">
        {skills.map((s) => <span class="chip">{s}</span>)}
      </div>
      <p class="meta" style="margin-top:14px">English: working proficiency, years of English-only daily standups. Czech: native.</p>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">contact <span class="flag">--now</span></span></p>
    <div class="blk out">
      <a href="mailto:vladislav.rajtmajer1@gmail.com">vladislav.rajtmajer1@gmail.com</a> ·
      <a href="https://github.com/rajtik76">github.com/rajtik76</a> ·
      <a href="https://laravel-blog.cz">laravel-blog.cz</a>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cmd">cv <span class="flag">--download</span></span></p>
    <div class="blk out">
      <a href="/cv.pdf" download="Vladislav-Rajtmajer-CV.pdf">Download CV (PDF, English)</a>
    </div>

    <p class="pr"><b>vladislav@rajtik</b>:<span class="tilde">~</span>$ <span class="cursor"></span></p>

  </div>
</main>
<footer>Plzeň, CZ</footer>

<style>
  :root{
    --bg:#0c0e10; --panel:#13161a; --fg:#d8d4ca; --dim:#7d848c;
    --amber:#f0a500; --teal:#54c7ab; --line:#22272d;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    margin:0; background:var(--bg); color:var(--fg);
    font-family:"JetBrains Mono",ui-monospace,Menlo,monospace;
    font-size:15px; line-height:1.7; letter-spacing:-.1px;
    -webkit-font-smoothing:antialiased;
  }
  a{color:var(--teal); text-decoration:none; border-bottom:1px solid transparent}
  a:hover{border-bottom-color:var(--teal)}

  .term{margin:40px auto; max-width:880px; border:1px solid var(--line);
        border-radius:10px; background:var(--panel); overflow:hidden;
        box-shadow:0 30px 80px -40px #000}
  .bar{display:flex; align-items:center; gap:8px; padding:11px 16px;
       border-bottom:1px solid var(--line); background:#0f1215}
  .dot{width:11px; height:11px; border-radius:50%}
  .dot.r{background:#ff5f56} .dot.y{background:#ffbd2e} .dot.g{background:#27c93f}
  .bar .path{margin-left:10px; color:var(--dim); font-size:12.5px}
  .body{padding:26px 26px 34px}

  .pr{color:var(--dim); margin:0}
  .pr b{color:var(--teal); font-weight:500}
  .pr .tilde{color:var(--amber)}
  .pr .cmd{color:var(--fg)}
  .blk{margin:6px 0 30px; padding-left:2px}
  .flag{color:var(--amber)}
  .cursor{display:inline-block; width:9px; height:1.05em; vertical-align:-2px;
          background:var(--amber); animation:blink 1.1s steps(1) infinite; margin-left:3px}
  @keyframes blink{50%{opacity:0}}

  h1{font-size:30px; margin:14px 0 2px; font-weight:700; letter-spacing:-1px}
  .role{color:var(--amber); font-size:15px; margin:0 0 4px}
  .meta{color:var(--dim); font-size:13px; margin:0 0 8px}
  .avail{font-size:13px; color:#27c93f; margin:0 0 8px}
  .ok{display:inline-block; width:8px; height:8px; border-radius:50%; background:#27c93f;
      margin-right:7px; vertical-align:1px; box-shadow:0 0 8px #27c93f}
  .out{color:var(--fg)} .dim{color:var(--dim)}

  .grid{display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:10px}
  .card{border:1px solid var(--line); border-radius:8px; padding:16px 18px; background:#0f1216}
  .card h3{margin:0 0 4px; font-size:15px; color:var(--fg)}
  .card .tag{color:var(--teal); font-size:12px}
  .card p{margin:8px 0 0; font-size:13.5px; color:var(--dim); line-height:1.6}
  .badge{display:inline-block; font-size:11.5px; color:var(--amber);
         border:1px solid #3a2f12; background:#1a1407; padding:1px 7px; border-radius:4px; margin:10px 0 0}

  .pkg{display:flex; justify-content:space-between; gap:14px; padding:11px 0;
       border-bottom:1px dashed var(--line); flex-wrap:wrap}
  .pkg .name{color:var(--fg)} .pkg .reg{color:var(--dim); font-size:12.5px}

  .exp{display:grid; grid-template-columns:118px 1fr; gap:4px 18px; padding:9px 0; border-top:1px solid var(--line)}
  .exp:first-of-type{border-top:0}
  .exp .yr{color:var(--dim); font-size:13px}
  .exp .ro{color:var(--fg)} .exp .co{color:var(--teal); font-size:13px}
  .exp .de{color:var(--dim); font-size:13px; grid-column:2}

  .chips{display:flex; flex-wrap:wrap; gap:7px; margin-top:8px}
  .chip{font-size:12.5px; color:var(--fg); border:1px solid var(--line); padding:2px 9px; border-radius:5px; background:#0f1216}

  footer{color:var(--dim); font-size:12.5px; text-align:center; padding:26px 0 50px}

  @media(max-width:620px){
    .grid{grid-template-columns:1fr}
    .exp{grid-template-columns:1fr}
    .exp .de{grid-column:1}
    .term{margin:20px auto; border-radius:0; border-left:0; border-right:0}
  }
</style>
</body>
</html>
